<?xml version="1.0" encoding="UTF-8"?>
<Configuration>

  <Appenders>
    <Console name="Console" target="SYSTEM_OUT">
      <PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss.SSS} [%t] %-5level %logger{36} - %msg%n"/>
    </Console>
    
    <File name="MyFile" fileName="${sys:catalina.base}/logs/app.log">
      <PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss.SSS} [%t] %-5level %logger{36} - %msg%n"/>
    </File>
  </Appenders>

  <Loggers>
  	<!-- 여기에 로거 추가 (모든 로거의 기본 성질)-->
<!--   	 SQL_LOGGER
	<Logger name="log4jexam.sql.Query" level="trace"></Logger> T04MemberInfoTest.java -->
<!-- 	PARAM_LOGGER
	<Logger name="log4jexam.sql.Parameter" level="info"></Logger> -->
<!-- 	RESULT_LOGGER 
	<Logger name="kr.or.ddit.basic.T04MemberInfoTest" level="error"></Logger>-->
	

 	<Logger name="log4jexam.sql" level="debug">
		 <AppenderRef ref="MyFile"/>
	</Logger>
	
    <Root level="trace">
      <AppenderRef ref="Console"/>
    </Root>
  </Loggers>

</Configuration>





