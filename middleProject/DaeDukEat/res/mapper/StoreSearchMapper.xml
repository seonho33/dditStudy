<!-- 가게 목록 조회 -->
<select id="storeSearchCategory" parameterType="map" resultType="store">
    SELECT 
        s.STORE_ID   AS storeId,
        s.STORE_NAME AS storeName,
        s.CATEGORY   AS category,
        s.STORE_CONTENT AS storeContent,
        s.RATING     AS rating,
        s.DIBS_COUNT AS dibsCount,
        s.LIKES_COUNT AS likesCount,
        s.STORE_PICTURE AS storePicture,
        MAX(r.REVIEW) AS review  <!-- 최신 리뷰를 가져오기 위해 MAX 사용 -->
    FROM store s
    LEFT JOIN reservation rsv ON s.STORE_ID = rsv.STORE_ID
    LEFT JOIN user_review r ON rsv.RESERV_ID = r.RESERV_ID
    WHERE s.STATUS = '승인'
    
    <!-- 전체보기가 아닐 때만 카테고리 필터링 -->
    <if test="category != null and category != '' and category != '전체보기'">
        AND s.CATEGORY = #{category}
    </if>

    <!-- GROUP BY로 각 가게에 대해 집계 -->
    GROUP BY 
        s.STORE_ID,
        s.STORE_NAME,
        s.CATEGORY,
        s.STORE_CONTENT,
        s.RATING,
        s.DIBS_COUNT,
        s.LIKES_COUNT,
        s.STORE_PICTURE
    
    <!-- 동적 정렬 -->
    ORDER BY
    <choose>
        <when test="sort == 'dibs'">
            s.DIBS_COUNT DESC  <!-- 찜 많은 순 -->
        </when>
        <when test="sort == 'likes'">
            s.LIKES_COUNT DESC  <!-- 좋아요(리뷰) 많은 순 -->
        </when>
        <when test="sort == 'distance'">
            s.STORE_ID ASC  <!-- 거리 가까운 순 (임시: ID 오름차순) -->
        </when>
        <otherwise>
            s.DIBS_COUNT DESC  <!-- 기본값: 찜 많은 순 -->
        </otherwise>
    </choose>
</select>


		

		
    

	


