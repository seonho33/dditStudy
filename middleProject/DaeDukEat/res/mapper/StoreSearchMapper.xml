<select id="selectStoreSearch" resultType="store">
  SELECT
      s.STORE_ID        AS storeId,
      s.STORE_NAME      AS storeName,
      s.CATEGORY        AS category,
      s.RATING          AS rating,
      s.DIBS_COUNT      AS dibsCount,
      s.LIKES_COUNT     AS likesCount,
      s.REVIEW_COUNT    AS reviewCount,
      s.STORE_PICTURE   AS storePicture,
      s.STORE_CONTENT   AS storeContent,
      rv.REVIEW         AS review,
      rv.RATING         AS reviewRating,
      rv.REVIEW_PICTURE AS reviewPicture
  FROM store s

  <!-- ✅ 가게 기준 최신 리뷰 1개 -->
  LEFT JOIN (
      SELECT
          STORE_ID,
          REVIEW,
          RATING,
          REVIEW_PICTURE
      FROM (
          SELECT
              r.STORE_ID,
              ur.REVIEW,
              ur.RATING,
              ur.REVIEW_PICTURE,
              ROW_NUMBER() OVER (
                  PARTITION BY r.STORE_ID
                  ORDER BY ur.CREATE_DATE DESC
              ) rn
          FROM reservation r
          JOIN user_review ur
              ON r.RESERV_ID = ur.RESERV_ID
          WHERE ur.STATUS = '정상'
      )
      WHERE rn = 1
  ) rv
      ON s.STORE_ID = rv.STORE_ID

  WHERE s.STATUS = '승인'

  <!-- 🔍 검색어 (가게명 OR 메뉴명) -->
  <if test="keyword != null and keyword != ''">
    AND (
      UPPER(s.STORE_NAME) LIKE UPPER('%' || #{keyword} || '%')
      OR EXISTS (
          SELECT 1
          FROM menu m
          WHERE m.STORE_ID = s.STORE_ID
            AND UPPER(m.MENU_NAME) LIKE UPPER('%' || #{keyword} || '%')
      )
    )
  </if>

  <!-- 🍜 태그 -->
  <if test="tag != null and tag != ''">
    AND (
      UPPER(s.STORE_NAME) LIKE UPPER('%' || #{tag} || '%')
      OR EXISTS (
          SELECT 1
          FROM menu m
          WHERE m.STORE_ID = s.STORE_ID
            AND UPPER(m.MENU_NAME) LIKE UPPER('%' || #{tag} || '%')
      )
    )
  </if>

  ORDER BY
  <choose>
    <when test="sort == 'dibs'">
      s.DIBS_COUNT DESC
    </when>
    <when test="sort == 'likes'">
      s.LIKES_COUNT DESC
    </when>
    <when test="sort == 'distance'">
      s.STORE_ID ASC
    </when>
    <otherwise>
      s.DIBS_COUNT DESC
    </otherwise>
  </choose>
</select>








