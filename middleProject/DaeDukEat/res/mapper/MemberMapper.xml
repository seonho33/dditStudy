<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" 
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="member">

    <!-- ResultMap: MEMBER + USERS 조인 -->
    <resultMap id="memberMap" type="memberVO">
        <id property="userId" column="USER_ID"/>
        <result property="userBir" column="USER_BIR"/>
        <result property="userMail" column="USER_MAIL"/>
        <result property="userNo" column="USER_NO"/>
        <result property="profileImg" column="PROFILE_IMG"/>
        
        <!-- USERS 테이블 정보 -->
        <result property="name" column="NAME"/>
        <result property="division" column="DIVISION"/>
        <result property="blockYn" column="BLOCK_YN"/>
        <result property="useYn" column="USE_YN"/>
    </resultMap>

    <!-- 회원 정보 조회 (USERS + MEMBER 조인) -->
    <select id="selectMemberById" parameterType="string" resultMap="memberMap">
        SELECT 
            M.USER_ID, M.USER_BIR, M.USER_MAIL, M.USER_NO, M.PROFILE_IMG,
            U.NAME, U.DIVISION, U.BLOCK_YN, U.USE_YN
        FROM MEMBER M
        INNER JOIN USERS U ON M.USER_ID = U.USER_ID
        WHERE M.USER_ID = #{userId}
          AND U.USE_YN = 'Y'
    </select>

    <!-- 회원 정보 수정 -->
    <update id="updateMember" parameterType="memberVO">
        UPDATE MEMBER
        SET USER_MAIL = #{userMail},
            USER_BIR = #{userBir}
        WHERE USER_ID = #{userId}
    </update>

    <!-- 회원 탈퇴 (USE_YN = 'N') -->
    <update id="deactivateMember" parameterType="string">
        UPDATE USERS
        SET USE_YN = 'N'
        WHERE USER_ID = #{userId}
    </update>

</mapper>