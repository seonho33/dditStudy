<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="kr.or.ddit.store.dao.IUserDao">

    <insert id="insertUser" parameterType="uvo">
        INSERT INTO USERS (
            USER_ID,
            PASSWORD,
            NAME,
            DIVISION,
            BLOCK_YN,
            USE_YN,
            CREATE_DATE	
        ) VALUES (
            #{userId},
            #{password},
            #{name},
            #{division},
            'N',
            'Y',
            SYSDATE
        )
    </insert>

    <select id="selectUserById"
            parameterType="string"
            resultType="uvo">
        SELECT *
        FROM USERS
        WHERE USER_ID = #{userId}
    </select>

</mapper>
