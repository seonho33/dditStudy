<?xml version="1.0" encoding="UTF-8"?>

<!DOCTYPE mapper   PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace = "reply">


<insert id="replyInsert" parameterType="rvo">
insert into replytab(renum,bonum,name,cont,redate)
values(REPLYTAB_RENUM_SEQ.NEXTVAL, #{bonum},#{name},#{cont},sysdate)
</insert>

<select id="replyList" resultType="rvo">
	select * from replytab where bonum=#{data}
</select>

<delete id="replyDelete" parameterType="int">

	DELETE	FROM	REPLYTAB
	WHERE	RENUM = #{data}

</delete>

</mapper>