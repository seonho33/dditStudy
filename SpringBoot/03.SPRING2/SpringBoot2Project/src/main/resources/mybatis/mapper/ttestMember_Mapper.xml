<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="kr.or.ddit.testMember.mapper.ITTestMapper">

<!-- 유저등록 -->
<insert id="register" parameterType="kr.or.ddit.vo.crud.CrudMember" useGeneratedKeys="true">
	<selectKey keyProperty="userNo" order="BEFORE" resultType="int" >
		select seq_member.nextval from dual
	</selectKey>
insert into member(
	USER_NO, 
	USER_ID, 
	USER_PW, 
	USER_NAME 
)values(
	#{userNo},
	#{userId},
	#{userPw},
	#{userName}
)
</insert>

<insert id="create" parameterType="kr.or.ddit.vo.crud.CrudMemberAuth">
	insert into MEMBER_AUTH(
		user_no,
		auth
	)values(
		#{userNo},
		#{auth}
	)
</insert>

<select id="getList" resultType="kr.or.ddit.vo.crud.CrudMember">
	select	user_no,
			user_id,
			user_name,
			reg_date,
			upd_date
	from	member		
</select>

<resultMap type="kr.or.ddit.vo.crud.CrudMember" id="memberMap">
	<id property="userNo" column="user_no"/>
	<result property="userNo" column="user_no" />
	<result property="userId" column="user_id" />
	<result property="userPw" column="user_pw" />
	<result property="userName" column="user_name" />
	<result property="regDate" column="reg_date" />
	<result property="updDate" column="upd_date" />
	<collection property="authList" resultMap="authMap"></collection>
</resultMap>

<resultMap type="kr.or.ddit.vo.crud.CrudMemberAuth" id="authMap">
	<result property="userNo" column="user_no"/>
	<result property="auth" column="auth"/>
</resultMap>

<select id="read" parameterType="int" resultMap="memberMap">
	select	m.user_no,
			m.user_Id,
			m.user_Pw,
			m.user_Name,
			m.reg_Date,
			m.upd_Date,
			ma.auth
	from	member m
	left join member_auth ma
			on(m.user_no = ma.user_no)
	where	m.user_no=#{userNo}
</select>

</mapper>